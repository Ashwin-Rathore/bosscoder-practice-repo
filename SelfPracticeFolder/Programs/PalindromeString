let s = "race a car";
//"A man, a plan, a canal: Panama";

var solve = function (s) {
  let newString = s.replace(/[^a-zA-Z0-9]/g, "").toLowerCase();
  console.log(newString);
  let left = 0;
  let right = newString.length - 1;
  console.log(left, right);

  while (left < right) {
    if (newString[left] !== newString[right]) {
      return false;
    }
    left++;
    right--;
  }

  return true;
};
console.log(solve(s));
